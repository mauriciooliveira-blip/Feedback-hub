# ---------- Database (MySQL) ----------
# Obrigatoria. Use senha forte e unica.
MYSQL_ROOT_PASSWORD=change-this-root-password

# Opcional (padrao: feedback_hub)
MYSQL_DATABASE=feedback_hub

# Obrigatorias para usuario da aplicacao (backend)
MYSQL_APP_USER=feedback_user
MYSQL_APP_PASSWORD=change-this-app-password

# ---------- Backend ----------
# Obrigatoria. Segredo JWT forte.
JWT_SECRET=change-this-jwt-secret

# Obrigatoria para CORS em producao (dominio/IP publico do frontend)
# Exemplo: https://app.seudominio.com
CORS_ORIGIN=http://SEU_IP_OU_DOMINIO

# Opcional: login inicial recomendado
DEFAULT_LOGIN_EMAIL=admin@feedbackhub.com

# ---------- Frontend / Proxy ----------
# Opcional (padrao: 80)
FRONTEND_PORT=80
